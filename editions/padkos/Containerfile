# Macrosofty Padkos — older hardware + offline-first edition.
# Upstream: Universal Blue Aurora (same as Hearty), with browser and
# office pre-installed as RPMs so the desktop is usable on day one
# without WiFi. Aurora itself rides standard Fedora Kinoite (generic
# x86-64, no v3 pin), which is exactly what we want for old hardware.

FROM scratch AS ctx
COPY editions/padkos /edition
COPY system_files /system_files
COPY scripts /scripts
COPY config /config

FROM ghcr.io/ublue-os/aurora:stable

ARG EDITION=padkos
ARG MACROSOFTY_VERSION=0.1.0-dev
# DEV-ONLY opt-in: `--build-arg DEV_SSHD=1` enables sshd + seeds the maintainer
# key (see editions/padkos/build.sh). Default 0 — public CI never sets it.
ARG DEV_SSHD=0

RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    DEV_SSHD="${DEV_SSHD:-0}" /ctx/edition/build.sh

RUN bootc container lint
