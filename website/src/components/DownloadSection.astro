---
const downloads = [
  { name: 'Hearty',  emoji: '🍲', line: 'Everyday machine, just works',             color: 'text-hearty',  rgb: '#C66B3D' },
  { name: 'Chunky',  emoji: '🍖', line: 'Work horse, office + dev',                color: 'text-chunky',  rgb: '#B04638' },
  { name: 'Broth',   emoji: '🥣', line: 'Revives older, lighter hardware',         color: 'text-bubbles', rgb: '#7A8868' },
  { name: 'Feast',   emoji: '🍷', line: 'Gaming, Steam, controllers, Proton',      color: 'text-feast',   rgb: '#6B2C39' },
];
---

<section id="download" class="py-24 sm:py-32 bg-cream-50 border-y border-cream-300 relative">
  <div class="max-w-6xl mx-auto px-6 sm:px-8">
    <div class="flex items-center gap-3 text-sm font-mono text-ink-500 mb-6">
      <span>08</span>
      <span class="w-8 h-px bg-broth-light opacity-60"></span>
      <span class="tracking-widest uppercase text-xs">Download</span>
    </div>

    <div class="grid grid-cols-12 gap-8 items-end mb-14">
      <div class="col-span-12 md:col-span-8">
        <h2 class="font-display text-4xl sm:text-5xl md:text-6xl leading-[1.05] tracking-tight mb-6">
          Almost ready.
          <span class="italic text-broth block">Not quite yet.</span>
        </h2>
        <p class="max-w-prose text-lg text-ink-700 leading-relaxed">
          Macrosofty is pre-release. The ISOs aren't signed and published yet. Drop your email below and we'll tell you exactly once, when the first edition is ready to install. No newsletter, no follow-ups, no selling the list. One email, then silence unless you want to hear from us.
        </p>
      </div>
      <div class="col-span-12 md:col-span-4 text-sm font-mono uppercase tracking-widest text-ink-500 md:text-right">
        <p>Target: <span class="text-ink-900">Hearty first</span></p>
        <p class="mt-1">Others follow within weeks</p>
      </div>
    </div>

    {/* Notify form — graceful placeholder, no backend wired yet */}
    <form
      action="#"
      method="post"
      class="mb-14 flex flex-col sm:flex-row gap-3 max-w-xl"
      aria-label="Get notified when Macrosofty is ready"
    >
      <label class="flex-1">
        <span class="sr-only">Your email</span>
        <input
          type="email"
          name="email"
          placeholder="you@somewhere.tld"
          required
          disabled
          class="w-full px-5 py-3.5 bg-cream-100 border border-ink-300 rounded-full text-ink-900 placeholder:text-ink-500 focus:border-ink-900 focus:outline-none transition-colors disabled:opacity-70 disabled:cursor-not-allowed"
        />
      </label>
      <button type="submit" class="btn-primary justify-center cursor-not-allowed opacity-70" disabled>
        Get notified
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8 H13 M9 4 L13 8 L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <!-- TODO: wire form to Cloudflare Pages Functions + Buttondown/Listmonk when ready. -->
    </form>

    <p class="text-xs font-mono uppercase tracking-widest text-ink-500 mb-10">
      Once the ISOs exist, the four buttons below light up:
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {downloads.map(d => (
        <div
          class="relative p-6 bg-cream-100 border border-cream-300 rounded-soft cursor-not-allowed opacity-80 shadow-marshmallow"
          aria-disabled="true"
          style={`color: ${d.rgb};`}
        >
          <div class="flex items-start justify-between mb-3">
            <span class="text-3xl" aria-hidden="true">{d.emoji}</span>
            <span class="font-mono text-[10px] uppercase tracking-widest text-ink-500">Coming soon</span>
          </div>
          <p class="font-display text-2xl font-medium text-ink-900 mb-1">{d.name}</p>
          <p class="text-ink-600 text-sm leading-relaxed mb-4">{d.line}</p>
          <div class="pt-3 border-t border-cream-300 flex items-center justify-between text-xs font-mono uppercase tracking-widest text-ink-500">
            <span>ISO · ~5 GB</span>
            <span style={`color: ${d.rgb};`}>soon</span>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-sm text-ink-600 leading-relaxed max-w-prose">
      <strong class="text-ink-900 font-medium">About SourceForge:</strong> we host ISOs there because it's free and mirrored worldwide. Yes, we know the reputation. The links will go directly to the file and skip the sponsored interstitials. Every ISO will be published with its SHA256 sum and a <code class="font-mono text-xs bg-cream-200 px-1.5 py-0.5 rounded">cosign</code> signature, verifiable in a one-liner.
    </p>
  </div>
</section>
