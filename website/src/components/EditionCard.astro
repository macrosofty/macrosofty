---
interface Props {
  id: string;
  emoji: string;
  name: string;
  tagline: string;
  body: string;
  wink: string;
  bestFor: string;
  minSpec: string;
  color: string;
  rgb: string;
}

const { id, emoji, name, tagline, body, wink, bestFor, minSpec, color, rgb } = Astro.props;
---

<article
  id={id}
  class="edition-card group"
  style={`color: ${rgb};`}
  data-edition={name.toLowerCase()}
>
  <div class="flex items-start justify-between mb-6">
    <span class="text-5xl" aria-hidden="true">{emoji}</span>
    <span class="font-mono text-[10px] uppercase tracking-widest text-ink-500 mt-2">
      Edition
    </span>
  </div>

  <h3 class="font-display text-3xl md:text-4xl font-medium tracking-tight text-ink-900 mb-2">
    Macrosofty <span style={`color: ${rgb};`}>{name}</span>
  </h3>
  <p class="font-display italic text-lg text-ink-700 mb-5">{tagline}</p>

  <p class="text-ink-600 leading-relaxed text-[0.95rem] mb-5">{body}</p>

  <p class="text-ink-500 italic text-sm leading-relaxed mb-8">
    {wink}
  </p>

  <div class="mt-auto pt-5 border-t border-cream-300 space-y-2 text-xs font-mono uppercase tracking-wider text-ink-500">
    <div class="flex justify-between gap-4">
      <span>Best for</span>
      <span class="text-ink-800 text-right normal-case tracking-normal font-sans">{bestFor}</span>
    </div>
    <div class="flex justify-between gap-4">
      <span>Minimum spec</span>
      <span class="text-ink-800 text-right normal-case tracking-normal font-sans">{minSpec}</span>
    </div>
  </div>

  {/* "Download" link — honest placeholder */}
  <a
    href="#download"
    class="mt-6 flex items-center justify-between pt-4 border-t border-cream-300 text-sm font-medium text-ink-900 hover:gap-3 transition-all duration-300"
    aria-label={`Go to ${name} download section`}
  >
    <span>See download options</span>
    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
      <path d="M3 8 H13 M9 4 L13 8 L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</article>
