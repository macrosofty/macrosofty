---
import DoorArch from './DoorArch.astro';
---

<header class="relative overflow-hidden">
  {/* Ambient soft orbs — drift slowly behind everything */}
  <div aria-hidden="true" class="soft-orb animate-float-slow" style="width: 520px; height: 520px; top: -180px; right: -120px; background: radial-gradient(circle, rgba(247, 212, 192, 0.8), transparent 60%);"></div>
  <div aria-hidden="true" class="soft-orb animate-float-slower" style="width: 380px; height: 380px; top: 260px; left: -140px; background: radial-gradient(circle, rgba(232, 154, 43, 0.18), transparent 60%); animation-delay: -6s;"></div>

  <nav class="max-w-6xl mx-auto px-6 sm:px-8 pt-8 flex items-center justify-between relative">
    <a href="/" class="flex items-center gap-2 group">
      <DoorArch variant="mini" class="w-5 h-6 text-ink-900 transition-transform duration-300 group-hover:-translate-y-0.5" />
      <span class="font-display text-xl font-medium tracking-tight">Macrosofty</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-ink-700">
      <a href="#editions" class="hover:text-ink-900 transition-colors">Editions</a>
      <a href="#can-do" class="hidden sm:inline hover:text-ink-900 transition-colors">What it does</a>
      <a href="#faq" class="hover:text-ink-900 transition-colors">FAQ</a>
      <a href="https://github.com/macrosofty" class="hidden sm:inline hover:text-ink-900 transition-colors font-mono text-xs">github</a>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-6 sm:px-8 pt-16 sm:pt-28 pb-24 sm:pb-32 relative">
    <div class="flex items-center gap-3 text-sm font-mono text-ink-500 mb-8 animate-fade-in">
      <span>00</span>
      <span class="w-8 h-px bg-broth-light opacity-60"></span>
      <span class="tracking-widest uppercase text-xs">Front door</span>
    </div>

    {/* Chips row — the brand promises, loud and legible */}
    <div class="flex flex-wrap items-center gap-2.5 mb-10 animate-fade-in" style="animation-delay: 60ms;">
      <span class="chip">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-bubbles"></span>
        Free for everyone
      </span>
      <span class="chip" style="background: theme('colors.cream.50'); color: theme('colors.broth.dark'); border-color: theme('colors.cream.300');">
        No ads · No accounts · No trackers
      </span>
      <span class="chip" style="background: theme('colors.ink.900'); color: theme('colors.cream.50'); border-color: theme('colors.ink.900');">
        Peace, not war
      </span>
    </div>

    <div class="grid grid-cols-12 gap-8 items-end">
      <div class="col-span-12 lg:col-span-8">
        <h1 class="font-display text-[clamp(3rem,9vw,7rem)] leading-[0.95] tracking-tight font-medium animate-fade-up">
          A Linux that<br />
          <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;">doesn't</span> suck.
        </h1>

        <p class="mt-10 max-w-xl text-lg sm:text-xl leading-relaxed text-ink-700 animate-fade-up" style="animation-delay: 120ms;">
          No ads. No accounts. No nonsense. Just a computer that respects you.
          <span class="block mt-2 text-ink-600">Free for everyone. Always.</span>
        </p>

        <p class="mt-5 max-w-xl text-base text-ink-600 italic font-display animate-fade-up" style="animation-delay: 180ms;">
          "We open the door — not just a window to peek through."
        </p>

        <p class="mt-4 max-w-xl text-sm text-ink-500 font-mono animate-fade-up" style="animation-delay: 210ms;">
          <span class="text-broth">macro</span> · big &nbsp;·&nbsp; <span class="text-broth">softy</span> · easy &nbsp;·&nbsp; <span class="italic font-display text-ink-700 normal-case">Become a Macrosofty.</span>
        </p>

        <div class="mt-12 flex flex-wrap items-center gap-4 animate-fade-up" style="animation-delay: 240ms;">
          <a href="#editions" class="btn-primary">
            See the editions
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8 H13 M9 4 L13 8 L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#download" class="btn-ghost">
            Download
          </a>
          <span class="font-mono text-xs text-ink-500 ml-2 flex items-center gap-1.5">
            <span class="inline-block w-2 h-2 rounded-full bg-saffron animate-pulse"></span>
            pre-release · coming soon
          </span>
        </div>
      </div>

      {/* Door illustration — plumper, warmer, ajar */}
      <div class="col-span-12 lg:col-span-4 hidden lg:flex justify-center animate-fade-in" style="animation-delay: 400ms;">
        <div class="relative">
          <div aria-hidden="true" class="absolute inset-0 -m-10 rounded-full bg-blush/40 blur-2xl"></div>
          <DoorArch variant="full" ajar={true} class="relative w-full max-w-[300px] mx-auto text-broth" />
        </div>
      </div>
    </div>

    {/* Trust signals — calm, pill-wrapped */}
    <div class="mt-24 flex flex-wrap items-center gap-x-6 gap-y-3 text-xs font-mono uppercase tracking-widest text-ink-500 animate-fade-in" style="animation-delay: 500ms;">
      <span>Built on Universal Blue</span>
      <span aria-hidden="true" class="text-blush-dark">◦</span>
      <span>Fedora Atomic</span>
      <span aria-hidden="true" class="text-blush-dark">◦</span>
      <span>KDE Plasma</span>
      <span aria-hidden="true" class="text-blush-dark">◦</span>
      <span>Apache&nbsp;2.0</span>
      <span aria-hidden="true" class="text-blush-dark">◦</span>
      <span>Signed with cosign</span>
    </div>
  </div>
</header>
