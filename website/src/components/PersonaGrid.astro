---
import DoorArch from './DoorArch.astro';

const personas = [
  {
    quote: "My computer has ads in it now. There has to be a better way.",
    recommendation: 'Hearty',
    color: 'text-hearty',
    rec_href: '#edition-hearty',
    body: "Your current setup added ads to the start menu, reboots mid-work, and keeps asking you to sign in to things. You're not looking for a project — you just want it to stop.",
  },
  {
    quote: "I'm setting up my mom's laptop and I can't be on-call for it forever.",
    recommendation: 'Hearty',
    color: 'text-hearty',
    rec_href: '#edition-hearty',
    body: "You're the family tech support. You want something that won't need a software update explained over WhatsApp at 9pm on a Tuesday.",
  },
  {
    quote: "I work on this thing all day. I need it to be fast and not get in my way.",
    recommendation: 'Chunky',
    color: 'text-chunky',
    rec_href: '#edition-chunky',
    body: "Office, PDFs, spreadsheets, lots of browser tabs, maybe some code. You care about focus, not about tweaking menus.",
  },
  {
    quote: "I have a perfectly good 2016 laptop. It just got ‘unsupported.'",
    recommendation: 'Padkos',
    color: 'text-bubbles',
    rec_href: '#edition-padkos',
    body: "4 GB of RAM, a slow-ish drive, and an OS that's giving up on it. Everything still works mechanically — the software is the problem, not the hardware.",
  },
  {
    quote: "I want to play games without the telemetry and 40GB updates.",
    recommendation: 'Braai',
    color: 'text-braai',
    rec_href: '#edition-braai',
    body: "You've heard about the Steam Deck. You're curious if that magic works on your actual PC. It does.",
  },
];
---

<section id="for-you" class="py-24 sm:py-32 relative">
  <div class="max-w-6xl mx-auto px-6 sm:px-8">
    <div class="flex items-center gap-3 text-sm font-mono text-ink-500 mb-6">
      <span>01</span>
      <span class="w-8 h-px bg-padkos-light opacity-60"></span>
      <span class="tracking-widest uppercase text-xs">Is this for you?</span>
    </div>

    <h2 class="font-display text-4xl sm:text-5xl md:text-6xl leading-[1.05] max-w-3xl mb-6 tracking-tight">
      Find yourself in one of these,<br />
      <span class="italic text-padkos">and you're in the right place.</span>
    </h2>

    <p class="max-w-prose text-lg text-ink-700 leading-relaxed mb-16">
      Macrosofty isn't for everyone. It's for people whose relationship with their computer has quietly got worse over the last few years, and who suspect it doesn't have to be that way.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 stagger" style="--stagger-delay: 100ms;">
      {personas.map((p, idx) => (
        <article
          class="group relative soft-card p-7 md:p-9"
          style={`--i: ${idx};`}
        >
          <DoorArch variant="mini" class={`w-5 h-6 mb-4 ${p.color}`} />
          <blockquote class="font-display text-xl md:text-2xl leading-snug text-ink-900 mb-4 italic">
            "{p.quote}"
          </blockquote>
          <p class="text-ink-600 leading-relaxed mb-6 text-[0.95rem]">
            {p.body}
          </p>
          <div class="flex items-center justify-between pt-4 border-t border-cream-300">
            <span class="text-xs font-mono uppercase tracking-widest text-ink-500">You want</span>
            <a href={p.rec_href} class={`font-display text-xl ${p.color} group-hover:underline underline-offset-4`}>
              Macrosofty {p.recommendation} →
            </a>
          </div>
        </article>
      ))}

      {/* Fifth card — the gentle "not for you, and that's fine" card */}
      <article class="md:col-span-2 relative bg-ink-900 text-cream-100 p-8 md:p-10 rounded-softer flex flex-col md:flex-row md:items-center gap-6 shadow-puff-lg">
        <DoorArch variant="mini" class="w-6 h-7 text-saffron flex-none" />
        <div class="flex-1">
          <p class="font-display text-xl md:text-2xl leading-snug mb-2 italic">
            "I love picking my own distro. I run Arch, by the way."
          </p>
          <p class="text-cream-200 text-[0.95rem] leading-relaxed">
            Then this isn't for you, and that's fine. Macrosofty is the Linux you hand to someone who doesn't want to think about distros. You're already sorted. Enjoy <code class="font-mono text-saffron-light">pacman -Syu</code>.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>
