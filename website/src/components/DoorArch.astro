---
interface Props {
  class?: string;
  variant?: 'full' | 'divider' | 'mini';
  ajar?: boolean;
}

const { class: className = '', variant = 'full', ajar = false } = Astro.props;
---

{variant === 'full' && (
  <svg
    class={className}
    viewBox="0 0 260 320"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    {/* Outer frame — plumper arch, softer base corners */}
    <path
      d="M 26 308 L 26 130 A 104 104 0 0 1 234 130 L 234 308 Q 234 312 230 312 L 30 312 Q 26 312 26 308 Z"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linejoin="round"
      fill="currentColor"
      fill-opacity="0.03"
    />
    {/* Inner door panel — chubbier */}
    <path
      d={ajar
        ? "M 46 308 L 46 142 A 84 84 0 0 1 142 94 L 142 308 Z"
        : "M 46 308 L 46 142 A 84 84 0 0 1 214 142 L 214 308 Z"}
      stroke="currentColor"
      stroke-width="1.25"
      stroke-linejoin="round"
      fill="currentColor"
      fill-opacity="0.08"
    />
    {/* Handle — bigger, softer */}
    <circle
      cx={ajar ? 130 : 192}
      cy="232"
      r="4"
      fill="currentColor"
    />
    {/* Inner panel — soft rounded rectangle, dashed */}
    <path
      d={ajar
        ? "M 60 178 Q 60 170 68 170 L 124 170 Q 132 170 132 178 L 132 270 Q 132 278 124 278 L 68 278 Q 60 278 60 270 Z"
        : "M 60 178 Q 60 170 68 170 L 192 170 Q 200 170 200 178 L 200 270 Q 200 278 192 278 L 68 278 Q 60 278 60 270 Z"}
      stroke="currentColor"
      stroke-width="0.9"
      stroke-dasharray="3 5"
      stroke-linecap="round"
      opacity="0.45"
      fill="none"
    />
    {/* A small threshold — grounds it */}
    <line
      x1="18" y1="312" x2="242" y2="312"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      opacity="0.6"
    />
  </svg>
)}

{variant === 'divider' && (
  <svg
    class={className}
    viewBox="0 0 220 44"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <line x1="0" y1="22" x2="76" y2="22" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.35" />
    {/* Plump mini-arch */}
    <path
      d="M 84 40 L 84 26 A 26 26 0 0 1 136 26 L 136 40"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linejoin="round"
      fill="currentColor"
      fill-opacity="0.05"
    />
    <circle cx="128" cy="32" r="1.8" fill="currentColor" />
    <line x1="144" y1="22" x2="220" y2="22" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.35" />
  </svg>
)}

{variant === 'mini' && (
  <svg
    class={className}
    viewBox="0 0 22 26"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      d="M 2.5 25 L 2.5 11 A 8.5 8.5 0 0 1 19.5 11 L 19.5 25 Q 19.5 25.5 19 25.5 L 3 25.5 Q 2.5 25.5 2.5 25 Z"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linejoin="round"
      fill="currentColor"
      fill-opacity="0.08"
    />
    <circle cx="15.5" cy="18" r="1" fill="currentColor" />
  </svg>
)}
