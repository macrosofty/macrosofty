---
// Side-by-side comparison table for the four shipping editions plus the tentative ARM "Bokkie".
// Designed to be scannable — rows are the questions a potential user actually asks.

type Support = 'yes' | 'partial' | 'no' | 'na';
interface Cell {
  t: string;          // cell text
  s?: Support;        // optional support badge
  sub?: string;       // optional subtle sub-text
}
interface Row {
  label: string;
  hint?: string;      // tooltip-ish hint (kept visible, small)
  cells: [Cell, Cell, Cell, Cell, Cell];   // Hearty, Chunky, Broth, Feast, Bokkie
}

const editions = [
  { key: 'hearty',  emoji: '🍲', name: 'Hearty',  tag: 'everyday',     rgb: '#C66B3D' },
  { key: 'chunky',  emoji: '🍖', name: 'Chunky',  tag: 'work',         rgb: '#B04638' },
  { key: 'broth',   emoji: '🥣', name: 'Broth',   tag: 'old hardware', rgb: '#7A8868' },
  { key: 'feast',   emoji: '🍷', name: 'Feast',   tag: 'gaming',       rgb: '#6B2C39' },
  { key: 'bokkie',  emoji: '🐰', name: 'Bokkie',  tag: 'ARM · tentative', rgb: '#8B5A3C' },
];

const rows: Row[] = [
  {
    label: 'Best for',
    cells: [
      { t: 'Daily driver'},
      { t: 'Work + dev'},
      { t: 'Older laptops'},
      { t: 'Gaming rigs'},
      { t: 'Pi 5 · ARM SBCs'},
    ],
  },
  {
    label: 'Architecture',
    cells: [
      { t: 'x86-64-v3', sub: '2015+ CPU'},
      { t: 'x86-64-v3', sub: '2015+ CPU'},
      { t: 'x86-64', sub: '2012+ CPU'},
      { t: 'x86-64-v3', sub: '2016+ CPU'},
      { t: 'aarch64', sub: 'Rockchip / Pi 5'},
    ],
  },
  {
    label: 'Min RAM',
    cells: [
      { t: '8 GB'},
      { t: '8 GB'},
      { t: '4 GB'},
      { t: '8 GB'},
      { t: '4 GB'},
    ],
  },
  {
    label: 'Pre-installed office',
    cells: [
      { t: 'LibreOffice', s: 'yes'},
      { t: 'OnlyOffice + LibreOffice', s: 'yes'},
      { t: 'LibreOffice', s: 'yes'},
      { t: 'LibreOffice', s: 'yes', sub: 'minimal'},
      { t: 'LibreOffice', s: 'partial'},
    ],
  },
  {
    label: 'Dev tools',
    cells: [
      { t: 'One-click install', s: 'partial'},
      { t: 'VS Code · Git · Podman · JetBrains Toolbox', s: 'yes'},
      { t: 'One-click install', s: 'partial'},
      { t: 'One-click install', s: 'partial'},
      { t: 'TBC', s: 'partial'},
    ],
  },
  {
    label: 'Steam + Proton',
    hint: 'Windows games via Proton',
    cells: [
      { t: 'One-click install', s: 'partial'},
      { t: 'One-click install', s: 'partial'},
      { t: 'Works but slow', s: 'partial'},
      { t: 'Curated + pre-configured', s: 'yes'},
      { t: 'No', s: 'no', sub: 'x86-only'},
    ],
  },
  {
    label: 'Controllers',
    hint: 'Xbox · DualSense · Switch Pro · generic',
    cells: [
      { t: 'Plug-and-play', s: 'yes'},
      { t: 'Plug-and-play', s: 'yes'},
      { t: 'Plug-and-play', s: 'yes'},
      { t: 'Tuned for Deck-class', s: 'yes'},
      { t: 'Plug-and-play', s: 'partial'},
    ],
  },
  {
    label: 'Low-latency kernel',
    cells: [
      { t: '', s: 'no'},
      { t: '', s: 'no'},
      { t: '', s: 'no'},
      { t: '', s: 'yes'},
      { t: '', s: 'no'},
    ],
  },
  {
    label: 'Atomic updates',
    hint: 'Whole-image swap · one-reboot rollback',
    cells: [
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
    ],
  },
  {
    label: 'One-click customisation',
    hint: 'Colour, wallpaper, cursor, icon pack',
    cells: [
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
    ],
  },
  {
    label: 'Signed with cosign',
    cells: [
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'yes'},
      { t: '', s: 'partial', sub: 'once images exist'},
    ],
  },
  {
    label: 'Status',
    cells: [
      { t: 'Pre-release', sub: 'Target: first'},
      { t: 'Pre-release'},
      { t: 'Pre-release'},
      { t: 'Pre-release'},
      { t: 'Still coming', sub: 'post-v1'},
    ],
  },
];

function supportBadge(s?: Support) {
  if (!s) return null;
  return s;
}
---

<section id="compare" class="py-24 sm:py-32 relative overflow-hidden">
  <div aria-hidden="true" class="soft-orb animate-float-slow" style="width: 500px; height: 500px; top: -100px; right: 10%; background: radial-gradient(circle, rgba(232, 154, 43, 0.10), transparent 60%);"></div>

  <div class="max-w-6xl mx-auto px-6 sm:px-8 relative">
    <div class="flex items-center gap-3 text-sm font-mono text-ink-500 mb-6">
      <span>02&middot;5</span>
      <span class="w-8 h-px bg-broth-light opacity-60"></span>
      <span class="tracking-widest uppercase text-xs">Side by side</span>
    </div>

    <div class="grid grid-cols-12 gap-8 items-end mb-10">
      <div class="col-span-12 md:col-span-8">
        <h2 class="font-display text-4xl sm:text-5xl md:text-6xl leading-[1.05] tracking-tight mb-5">
          Compare them<br />
          <span class="italic text-broth">side by side.</span>
        </h2>
        <p class="max-w-prose text-lg text-ink-700 leading-relaxed">
          Still can't pick? Scan the rows. Green means <span class="italic">"yes, this just works."</span> Amber means <span class="italic">"works, but needs one click."</span> Dashed means <span class="italic">"not yet — coming later."</span> We'd rather show you the honest line-up now than catfish you on download day.
        </p>
      </div>

      <div class="col-span-12 md:col-span-4 md:text-right">
        <span class="chip" style="background: theme('colors.blush.light'); color: theme('colors.broth.dark'); border-color: theme('colors.blush.DEFAULT');">
          Bokkie (ARM) is tentative
        </span>
      </div>
    </div>

    {/* Scroll hint on small screens */}
    <p class="mb-4 md:hidden text-xs font-mono uppercase tracking-widest text-ink-500 flex items-center gap-2">
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M2 8 H14 M10 4 L14 8 L10 12 M6 4 L2 8 L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Scroll horizontally to see all editions
    </p>

    <div class="overflow-x-auto rounded-softer border border-cream-300 bg-cream-50 shadow-marshmallow">
      <table class="w-full min-w-[900px] text-sm">
        {/* header row */}
        <thead>
          <tr class="border-b border-cream-300">
            <th class="text-left p-5 font-mono text-[10px] uppercase tracking-widest text-ink-500 align-bottom w-44">
              Feature
            </th>
            {editions.map(e => (
              <th
                scope="col"
                class={`text-left p-5 align-bottom ${e.key === 'bokkie' ? 'bg-cream-100/80' : ''}`}
                style={e.key === 'bokkie'
                  ? 'border-left: 2px dashed rgba(139, 90, 60, 0.35);'
                  : undefined}
              >
                <div class="flex items-baseline gap-2">
                  <span class="text-2xl leading-none" aria-hidden="true">{e.emoji}</span>
                  <div>
                    <div class="font-display text-xl font-medium tracking-tight leading-none mb-1" style={`color: ${e.rgb};`}>
                      {e.name}
                    </div>
                    <div class="font-mono text-[10px] uppercase tracking-widest text-ink-500">
                      {e.tag}
                    </div>
                  </div>
                </div>
              </th>
            ))}
          </tr>
        </thead>

        <tbody>
          {rows.map((row, rIdx) => (
            <tr class={`border-b border-cream-200 ${rIdx % 2 === 1 ? 'bg-cream-100/30' : ''}`}>
              <th scope="row" class="text-left p-5 font-medium text-ink-900 align-top w-44">
                <div class="leading-snug">{row.label}</div>
                {row.hint && (
                  <div class="mt-1 text-xs font-normal text-ink-500 leading-snug">{row.hint}</div>
                )}
              </th>
              {row.cells.map((cell, cIdx) => {
                const isBokkie = cIdx === 4;
                const s = supportBadge(cell.s);
                return (
                  <td
                    class={`p-5 align-top ${isBokkie ? 'bg-cream-100/60 text-ink-600' : ''}`}
                    style={isBokkie
                      ? 'border-left: 2px dashed rgba(139, 90, 60, 0.25);'
                      : undefined}
                  >
                    <div class="flex items-start gap-2 leading-snug">
                      {s === 'yes' && (
                        <span class="flex-none mt-0.5 w-5 h-5 rounded-full bg-bubbles/20 flex items-center justify-center" aria-label="yes">
                          <svg class="w-3 h-3 text-bubbles" viewBox="0 0 14 14" fill="none"><path d="M3 7 L6 10 L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </span>
                      )}
                      {s === 'partial' && (
                        <span class="flex-none mt-0.5 w-5 h-5 rounded-full bg-saffron/25 flex items-center justify-center" aria-label="partial">
                          <svg class="w-3 h-3 text-saffron-dark" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="3" fill="currentColor"/></svg>
                        </span>
                      )}
                      {s === 'no' && (
                        <span class="flex-none mt-0.5 w-5 h-5 rounded-full bg-chunky/20 flex items-center justify-center" aria-label="no">
                          <svg class="w-3 h-3 text-chunky" viewBox="0 0 14 14" fill="none"><path d="M4 4 L10 10 M10 4 L4 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        </span>
                      )}
                      <div class="flex-1">
                        {cell.t && <div>{cell.t}</div>}
                        {cell.sub && <div class="mt-0.5 text-xs text-ink-500">{cell.sub}</div>}
                      </div>
                    </div>
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {/* Legend */}
    <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3 text-xs font-mono uppercase tracking-widest text-ink-500">
      <span class="flex items-center gap-2">
        <span class="w-4 h-4 rounded-full bg-bubbles/20 flex items-center justify-center">
          <svg class="w-2.5 h-2.5 text-bubbles" viewBox="0 0 14 14" fill="none"><path d="M3 7 L6 10 L11 4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        Yes — just works
      </span>
      <span class="flex items-center gap-2">
        <span class="w-4 h-4 rounded-full bg-saffron/25 flex items-center justify-center">
          <svg class="w-2 h-2 text-saffron-dark" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="3" fill="currentColor"/></svg>
        </span>
        Partial — one extra step
      </span>
      <span class="flex items-center gap-2">
        <span class="w-4 h-4 rounded-full bg-chunky/20 flex items-center justify-center">
          <svg class="w-2.5 h-2.5 text-chunky" viewBox="0 0 14 14" fill="none"><path d="M4 4 L10 10 M10 4 L4 10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
        </span>
        No — can't help you there
      </span>
      <span class="flex items-center gap-2">
        <span class="w-4 h-4 rounded-sm border-2 border-dashed border-ink-400"></span>
        Dashed column = coming later
      </span>
    </div>

    {/* Bokkie callout */}
    <div class="mt-10 p-6 md:p-7 rounded-softer border-2 border-dashed border-cream-300 bg-cream-50/60 flex flex-col md:flex-row md:items-center gap-5">
      <span class="text-5xl leading-none" aria-hidden="true">🐰</span>
      <div class="flex-1">
        <p class="font-display text-xl md:text-2xl font-medium tracking-tight text-ink-900 mb-2">
          A note on Bokkie (ARM).
        </p>
        <p class="text-ink-700 leading-relaxed text-[0.95rem]">
          This column is <span class="italic">tentative</span>. Fedora Atomic already runs on aarch64 — Pi 5, Rockchip SBCs, Apple Silicon via Asahi — so the foundation is ready. What's missing is our Universal Blue inheritance path (Bluefin / Bazzite / Aurora are all x86-64 today). For v1 we ship the four x86 editions. A Bokkie release comes <span class="font-medium text-ink-900">after</span> the other four are stable, and it won't include Feast (Steam / Proton / Wine are x86 at heart — can't fix that). If you're excited for ARM, say so in GitHub Discussions once we're live — that moves it up the list.
        </p>
      </div>
    </div>
  </div>
</section>
