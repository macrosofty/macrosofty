---
import EditionCard from './EditionCard.astro';
import DoorArch from './DoorArch.astro';

const editions = [
  {
    id: 'edition-hearty',
    emoji: '🍲',
    name: 'Hearty',
    tagline: 'For the person who just wants it to work.',
    body: "The everyday edition. Browser, email, photos, video calls, Netflix, printing, messaging — all there on first boot. No terminal. No jargon. If this is going on your mom's laptop, this is the one.",
    wink: "Inside, a tag the door company would have called \"Basic\" and charged you for.",
    bestFor: 'Daily driver, family machines',
    minSpec: '8 GB RAM, 2015-or-later x86-64',
    color: 'hearty',
    rgb: '#C66B3D',
  },
  {
    id: 'edition-chunky',
    emoji: '🍖',
    name: 'Chunky',
    tagline: 'For the person who does real work on it.',
    body: 'Everything Hearty has, plus a full office suite, PDF editing that actually edits, better file management, developer tools if you want them, and a little more muscle behind the scenes. Runs well on anything made in the last 8 years.',
    wink: 'The one the door company would have called "Pro" and hidden behind a paywall.',
    bestFor: 'Knowledge workers, light dev',
    minSpec: '8 GB RAM, 2016-or-later x86-64',
    color: 'chunky',
    rgb: '#B04638',
  },
  {
    id: 'edition-broth',
    emoji: '🥣',
    name: 'Broth',
    tagline: 'For reviving an older machine.',
    body: "Boots fast on 4 GB of RAM. Does browsing, documents, email, video. Gets out of the way. Perfect for a second PC, an old Thinkpad, or a family member who just needs ‘the internet computer.'",
    wink: 'The edition the door company would have called "Essentials" and quietly retired after two years.',
    bestFor: 'Old laptops, second PCs',
    minSpec: '4 GB RAM, 2012-or-later x86-64',
    color: 'bubbles',
    rgb: '#7A8868',
  },
  {
    id: 'edition-feast',
    emoji: '🍷',
    name: 'Feast',
    tagline: 'For players.',
    body: 'Steam, Proton, Lutris, Heroic, Bottles — pre-configured and kept current. Controllers plug in and work. Games from Steam, Epic, GOG, Battle.net and classic discs run. Low-latency kernel. No driver archaeology.',
    wink: "The \"Ultimate\" edition. Slapped with a gamer skin by the door company, sold as a premium tier. Here, it's just the fourth download button. Built on Bazzite's work — we owe them a beer.",
    bestFor: 'Gaming rigs, Steam Deck friends',
    minSpec: '8 GB RAM, 2016-or-later x86-64, a GPU you like',
    color: 'feast',
    rgb: '#6B2C39',
  },
];
---

<section id="editions" class="py-24 sm:py-32 bg-cream-50 relative overflow-hidden">
  <div aria-hidden="true" class="soft-orb animate-float-slower" style="width: 520px; height: 520px; top: -180px; right: -120px; background: radial-gradient(circle, rgba(232, 154, 43, 0.12), transparent 60%);"></div>
  <div aria-hidden="true" class="soft-orb animate-float-slow" style="width: 400px; height: 400px; bottom: -160px; left: -80px; background: radial-gradient(circle, rgba(122, 136, 104, 0.12), transparent 60%); animation-delay: -4s;"></div>
  <div class="max-w-6xl mx-auto px-6 sm:px-8">
    <div class="flex items-center gap-3 text-sm font-mono text-ink-500 mb-6">
      <span>02</span>
      <span class="w-8 h-px bg-broth-light opacity-60"></span>
      <span class="tracking-widest uppercase text-xs">The four editions</span>
    </div>

    <div class="grid grid-cols-12 gap-8 items-end mb-16">
      <div class="col-span-12 md:col-span-8">
        <h2 class="font-display text-4xl sm:text-5xl md:text-6xl leading-[1.05] tracking-tight mb-6">
          Four recipes,<br />
          <span class="italic text-broth">one kitchen.</span>
        </h2>
        <p class="max-w-prose text-lg text-ink-700 leading-relaxed">
          Every edition is built from the same pipeline, signed with the same keys, and receives the same automatic rollback-safe updates. You're picking a flavor, not a fork.
        </p>
      </div>
      <div class="col-span-12 md:col-span-4 text-sm text-ink-600 leading-relaxed md:text-right">
        <p class="italic font-display">Pick one. You can change your mind.</p>
        <p class="mt-1">Rollback is always one reboot away.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {editions.map(e => <EditionCard {...e} />)}
    </div>

    <div class="mt-12 flex justify-center">
      <DoorArch variant="divider" class="w-40 h-8 text-broth" />
    </div>
  </div>
</section>
