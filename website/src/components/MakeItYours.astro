---
import DoorArch from './DoorArch.astro';

// "Make it yours, in one click" — the core product thesis:
// The system is opinionated (atomic, curated). The paint is yours.

const swatches = [
  { name: 'Warm',     bg: '#F5EFE6', accent: '#8B5A3C', text: '#1A1612', tag: 'default' },
  { name: 'Pink',     bg: '#FDE8EC', accent: '#E85A7A', text: '#2B0E15', tag: 'for gran' },
  { name: 'Dark',     bg: '#1A1612', accent: '#E89A2B', text: '#FBF8F2', tag: 'late nights' },
  { name: 'Bubblegum',bg: '#FFF4E6', accent: '#7B3FE4', text: '#1A1612', tag: 'playful' },
  { name: 'Forest',   bg: '#0F1F15', accent: '#7EC16C', text: '#E8F5E2', tag: 'focus' },
  { name: 'Ocean',    bg: '#E6F3F8', accent: '#0066A2', text: '#0A1F2C', tag: 'calm' },
];
---

<section id="make-it-yours" class="py-24 sm:py-32 relative overflow-hidden">
  {/* Ambient pink + saffron orbs — this section IS the colour point */}
  <div aria-hidden="true" class="soft-orb animate-float-slow" style="width: 520px; height: 520px; top: -160px; left: -80px; background: radial-gradient(circle, rgba(232, 90, 122, 0.22), transparent 60%);"></div>
  <div aria-hidden="true" class="soft-orb animate-float-slower" style="width: 420px; height: 420px; bottom: -120px; right: -100px; background: radial-gradient(circle, rgba(232, 154, 43, 0.20), transparent 60%); animation-delay: -5s;"></div>

  <div class="max-w-6xl mx-auto px-6 sm:px-8 relative">
    <div class="flex items-center gap-3 text-sm font-mono text-ink-500 mb-6">
      <span>03</span>
      <span class="w-8 h-px bg-broth-light opacity-60"></span>
      <span class="tracking-widest uppercase text-xs">Make it yours</span>
    </div>

    <div class="grid grid-cols-12 gap-8 mb-16 items-end">
      <div class="col-span-12 md:col-span-8">
        <h2 class="font-display text-4xl sm:text-5xl md:text-6xl leading-[1.02] tracking-tight mb-6">
          Make it yours,<br />
          <span class="italic text-broth">in one click.</span>
        </h2>

        <p class="max-w-prose text-lg md:text-xl text-ink-700 leading-relaxed mb-4">
          The system is <span class="italic font-display">opinionated.</span> Your desktop is <span class="italic font-display text-broth">yours.</span>
        </p>

        <p class="max-w-prose text-lg text-ink-700 leading-relaxed">
          We handle the plumbing. You handle the paint. Want everything pink? One click. Want your doggy on the wallpaper? Drop the photo in, done. Want it back to normal tomorrow? One click. Who's going to stop you?
        </p>
      </div>

      <div class="col-span-12 md:col-span-4 md:text-right">
        <div class="inline-flex flex-col gap-2 items-start md:items-end">
          <span class="chip" style="background: #FDE8EC; color: #8B2F4A; border-color: #F7C0CC;">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-hearty"></span>
            Pink + doggy approved
          </span>
          <span class="chip">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-bubbles"></span>
            No hex codes required
          </span>
        </div>
      </div>
    </div>

    {/* The hero example — pink palette with "your doggy here" spot */}
    <div class="grid grid-cols-12 gap-6 md:gap-8 mb-14">
      <div class="col-span-12 lg:col-span-8 relative">
        <div
          class="relative rounded-plump overflow-hidden shadow-puff-lg p-8 md:p-12 aspect-[16/9] flex flex-col justify-between"
          style="background: linear-gradient(135deg, #FDE8EC 0%, #F7C0CC 50%, #FAD4DC 100%);"
        >
          {/* Fake desktop top bar */}
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-white/40"></span>
            <span class="w-3 h-3 rounded-full bg-white/40"></span>
            <span class="w-3 h-3 rounded-full bg-white/40"></span>
            <span class="ml-auto font-mono text-xs uppercase tracking-widest text-ink-700/70">your desktop · 14:32</span>
          </div>

          {/* "Doggy here" placeholder circle */}
          <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
            <div class="w-32 h-32 md:w-40 md:h-40 rounded-full bg-white/40 border-4 border-white/60 backdrop-blur-sm flex items-center justify-center shadow-puff">
              <span class="text-5xl md:text-6xl" role="img" aria-label="dog">🐶</span>
            </div>
            <p class="text-center mt-4 font-display italic text-ink-900/70 text-sm">
              [ your doggy here ]
            </p>
          </div>

          {/* Fake dock */}
          <div class="mx-auto flex items-center gap-2 px-4 py-2 rounded-full bg-white/30 backdrop-blur-sm border border-white/40 shadow-marshmallow">
            <span class="w-6 h-6 rounded-md bg-white/60"></span>
            <span class="w-6 h-6 rounded-md bg-white/60"></span>
            <span class="w-6 h-6 rounded-md bg-white/60"></span>
            <span class="w-6 h-6 rounded-md" style="background: #E85A7A;"></span>
            <span class="w-6 h-6 rounded-md bg-white/60"></span>
          </div>
        </div>

        {/* Caption under the mock */}
        <div class="mt-4 flex items-center justify-between">
          <p class="text-sm font-mono uppercase tracking-widest text-ink-500">
            Theme: <span class="text-hearty">Pink</span> · Wallpaper: <span class="text-ink-800">My doggy</span>
          </p>
          <span class="text-xs font-mono text-ink-500 italic">mock — screenshot on launch day</span>
        </div>
      </div>

      {/* The "one-click" panel — list of things that are genuinely one-click */}
      <div class="col-span-12 lg:col-span-4">
        <div class="soft-card p-7 md:p-8 h-full flex flex-col">
          <div class="chip mb-5">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-saffron"></span>
            Genuinely one click
          </div>
          <ul class="space-y-4 flex-1">
            <li class="flex items-start gap-3">
              <span class="flex-none w-6 h-6 rounded-full bg-cream-200 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-broth" viewBox="0 0 14 14" fill="none"><path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-[0.95rem] text-ink-700">Colour palette — pick from 12 presets, or nudge the hue slider</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-none w-6 h-6 rounded-full bg-cream-200 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-broth" viewBox="0 0 14 14" fill="none"><path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-[0.95rem] text-ink-700">Wallpaper — drop any photo, we auto-crop it</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-none w-6 h-6 rounded-full bg-cream-200 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-broth" viewBox="0 0 14 14" fill="none"><path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-[0.95rem] text-ink-700">Cursor size — small, normal, thumbsized (for gran)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-none w-6 h-6 rounded-full bg-cream-200 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-broth" viewBox="0 0 14 14" fill="none"><path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-[0.95rem] text-ink-700">Text size — readable, roomy, large-print</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-none w-6 h-6 rounded-full bg-cream-200 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-broth" viewBox="0 0 14 14" fill="none"><path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-[0.95rem] text-ink-700">Icon pack — rounded, sharp, retro</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-none w-6 h-6 rounded-full bg-cream-200 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-broth" viewBox="0 0 14 14" fill="none"><path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-[0.95rem] text-ink-700">Reset to default — one click, no regret</span>
            </li>
          </ul>
          <p class="mt-6 pt-5 border-t border-cream-300 text-xs font-mono uppercase tracking-widest text-ink-500">
            No terminal. No config files. No .conf editing.
          </p>
        </div>
      </div>
    </div>

    {/* Palette swatches — showcase the one-click range */}
    <h3 class="font-display text-2xl md:text-3xl tracking-tight mb-6">
      Pick a vibe:
    </h3>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-12">
      {swatches.map((s, idx) => (
        <button
          type="button"
          class="group relative rounded-soft overflow-hidden border border-cream-300 aspect-[4/5] flex flex-col justify-between p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-puff"
          style={`background: ${s.bg}; --i: ${idx};`}
          aria-label={`Preview the ${s.name} theme`}
        >
          <span class="font-mono text-[10px] uppercase tracking-widest" style={`color: ${s.text}; opacity: 0.65;`}>
            {s.tag}
          </span>

          {/* Three rounded chips showing accent / body / button */}
          <div class="flex flex-col gap-1.5 items-start">
            <span class="w-12 h-2 rounded-full" style={`background: ${s.accent};`}></span>
            <span class="w-8 h-2 rounded-full" style={`background: ${s.text}; opacity: 0.4;`}></span>
            <span class="w-6 h-2 rounded-full" style={`background: ${s.text}; opacity: 0.25;`}></span>
          </div>

          <div class="flex items-end justify-between">
            <span class="font-display text-xl md:text-2xl font-medium tracking-tight" style={`color: ${s.text};`}>
              {s.name}
            </span>
            <span
              class="w-7 h-7 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
              style={`background: ${s.accent}; color: ${s.bg};`}
              aria-hidden="true"
            >
              <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none"><path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </button>
      ))}
    </div>

    {/* The reassurance — for the nerd who worries we've restricted them */}
    <div class="bg-cream-50 rounded-softer p-7 md:p-8 border border-cream-300 flex flex-col md:flex-row md:items-center gap-5 shadow-marshmallow">
      <DoorArch variant="mini" class="w-6 h-7 text-broth flex-none" />
      <p class="text-[0.95rem] md:text-base text-ink-700 leading-relaxed">
        <span class="font-medium text-ink-900">Under the surface:</span> it's still KDE Plasma, with every power-user lever intact. We built a friendly front door; we didn't lock the rest of the house. If you want to dive into global themes, Kvantum, Konsave profiles, or your own <code class="font-mono text-xs bg-cream-200 px-1.5 py-0.5 rounded">.desktop</code> files — the door's open. You just don't have to.
      </p>
    </div>
  </div>
</section>
