---
import DoorArch from './DoorArch.astro';
---

<footer class="bg-ink-900 text-cream-200 pt-20 pb-10 relative overflow-hidden">
  {/* Large background arch — decorative */}
  <DoorArch
    variant="full"
    class="absolute -right-20 -top-10 w-[500px] h-[625px] text-cream-100/[0.04] pointer-events-none"
  />

  <div class="max-w-6xl mx-auto px-6 sm:px-8 relative">
    <div class="grid grid-cols-12 gap-8 mb-16">
      <div class="col-span-12 md:col-span-6">
        <div class="flex items-center gap-2 mb-6">
          <DoorArch variant="mini" class="w-5 h-6 text-saffron" />
          <span class="font-display text-2xl font-medium tracking-tight text-cream-50">Macrosofty</span>
        </div>
        <p class="font-display text-2xl md:text-3xl italic text-cream-50 leading-snug max-w-md">
          "The door is always open."
        </p>
        <p class="mt-4 text-saffron/90 text-sm font-mono">
          Explained at a braai, not in a board meeting.
        </p>
        <p class="mt-6 text-cream-200/70 max-w-md text-sm leading-relaxed">
          A small love project — built on <a href="https://universal-blue.org" class="underline underline-offset-2 hover:text-saffron transition-colors">Universal Blue</a> and <a href="https://fedoraproject.org/atomic-desktops/" class="underline underline-offset-2 hover:text-saffron transition-colors">Fedora Atomic Desktops</a>. Without their work, none of this exists.
        </p>
      </div>

      <div class="col-span-6 md:col-span-3">
        <h4 class="font-mono text-[10px] uppercase tracking-widest text-cream-200/60 mb-4">Project</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="https://github.com/macrosofty" class="text-cream-100 hover:text-saffron transition-colors">GitHub</a></li>
          <li><a href="https://github.com/macrosofty/macrosofty/discussions" class="text-cream-100 hover:text-saffron transition-colors">Discussions</a></li>
          <li><a href="#" class="text-cream-100 hover:text-saffron transition-colors">Security policy</a></li>
          <li><a href="#" class="text-cream-100 hover:text-saffron transition-colors">Signing &amp; verification</a></li>
          <li><a href="#" class="text-cream-100 hover:text-saffron transition-colors">Attribution</a></li>
        </ul>
      </div>

      <div class="col-span-6 md:col-span-3">
        <h4 class="font-mono text-[10px] uppercase tracking-widest text-cream-200/60 mb-4">Editions</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#edition-hearty" class="text-cream-100 hover:text-saffron transition-colors">🍲 Hearty</a></li>
          <li><a href="#edition-chunky" class="text-cream-100 hover:text-saffron transition-colors">🍖 Chunky</a></li>
          <li><a href="#edition-padkos" class="text-cream-100 hover:text-saffron transition-colors">🧺 Padkos</a></li>
          <li><a href="#edition-braai" class="text-cream-100 hover:text-saffron transition-colors">🔥 Braai</a></li>
        </ul>
      </div>
    </div>

    {/* "Made with lekker in Mzansi" stripe — SA flag as tiny colour-bar */}
    <div class="mb-8 p-5 rounded-softer bg-cream-50/[0.04] border border-cream-200/10 flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <span class="sa-stripe flex-none" aria-label="South African flag colours">
          <span></span><span></span><span></span><span></span><span></span><span></span>
        </span>
        <p class="text-cream-100 font-display italic text-base md:text-lg">
          Made with <span class="text-saffron not-italic">lekker</span> in Mzansi.
        </p>
      </div>
      <p class="text-cream-200/60 text-xs font-mono uppercase tracking-widest">
        Peace, not war · Free for everyone · Forever
      </p>
    </div>

    <div class="pt-8 border-t border-cream-200/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-xs font-mono">
      <p class="text-cream-200/60">
        © Macrosofty · Apache-2.0 · No windows were harmed in the making of this operating system.
      </p>
      <p class="text-cream-200/60 flex items-center gap-3">
        <span>No analytics.</span>
        <span aria-hidden="true" class="w-1 h-1 bg-cream-200/30 rounded-full"></span>
        <span>No trackers.</span>
        <span aria-hidden="true" class="w-1 h-1 bg-cream-200/30 rounded-full"></span>
        <span>No cookies.</span>
      </p>
    </div>
  </div>
</footer>
