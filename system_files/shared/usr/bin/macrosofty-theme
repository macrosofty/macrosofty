#!/usr/bin/env bash
#
# macrosofty-theme — apply a Macrosofty theme pack to the running system.
#
# Usage:
#   macrosofty-theme apply <pack-name>     Apply a pack from /usr/share/macrosofty/themes/
#   macrosofty-theme list                  List installed packs
#   macrosofty-theme current               Show the currently applied pack
#
# Idempotent: re-running with the same pack is safe. Re-running with a
# different pack swaps cleanly. Most operations require root (file writes
# under /usr/share, /etc, regenerating initramfs); the script will exit
# early with a friendly error if not root.
#
# Pack format documented in /usr/share/macrosofty/themes/<pack>/pack.json.
# A pack's components are all optional — packs can be partial. The script
# only applies what's present.
#
# Components handled:
#   kickoffIcon     -> /usr/share/icons/hicolor/scalable/places/start-here-kde.svg
#                       (and start-here.svg, start-here-symbolic.svg for fallback)
#   wallpaper       -> /usr/share/wallpapers/Macrosofty/contents/images/1920x1080.png
#                       (with metadata.json)
#   loginBackground -> /usr/share/sddm/themes/breeze/Background.png (overlay)
#   motd            -> /etc/motd
#   grubDistributor -> /etc/default/grub.d/99-macrosofty.cfg (sets GRUB_DISTRIBUTOR)
#   grubBackground  -> /usr/share/grub/themes/macrosofty/background.png +
#                       /etc/default/grub.d/98-macrosofty-background.cfg

#   plymouthTheme   -> /usr/share/plymouth/themes/macrosofty/ + plymouth-set-default-theme
#                       + dracut --regenerate-all (skipped if no PNG/script in pack)
#   sddmBackground  -> same image used in loginBackground; overlayed on breeze theme
#   defaultWallpaper-> /usr/share/backgrounds/default.jxl (+ default-dark.jxl);
#                       the system default the first-run setup wizard + fresh
#                       sessions render against (overwrites the upstream symlink)
#   lookAndFeel     -> /usr/share/plasma/look-and-feel/com.macrosofty.desktop/
#                       (placeholder until we ship one)

set -euo pipefail

THEMES_ROOT="/usr/share/macrosofty/themes"
STATE_FILE="/var/lib/macrosofty/theme-current"

die()   { echo "macrosofty-theme: error: $*" >&2; exit 1; }
info()  { echo "macrosofty-theme: $*"; }
need_root() { [ "$(id -u)" -eq 0 ] || die "this command needs root (try with sudo)"; }

cmd_list() {
    [ -d "$THEMES_ROOT" ] || die "no themes directory at $THEMES_ROOT"
    for d in "$THEMES_ROOT"/*/; do
        [ -d "$d" ] || continue
        local name; name="$(basename "$d")"
        if [ -f "$d/pack.json" ]; then
            local display
            display=$(jq -r '.displayName // .name // empty' "$d/pack.json" 2>/dev/null || echo "")
            printf "  %-20s  %s\n" "$name" "${display:-(no displayName)}"
        else
            printf "  %-20s  (no pack.json)\n" "$name"
        fi
    done
}

cmd_current() {
    if [ -f "$STATE_FILE" ]; then
        cat "$STATE_FILE"
    else
        echo "(none applied)"
    fi
}

apply_kickoff_icon() {
    local pack_dir="$1" component="$2"
    local src="$pack_dir/$component"
    [ -f "$src" ] || { info "  skip kickoff icon (not in pack)"; return 0; }

    # Step 1 — drop our SVG at the standard KDE icon-theme names.
    # KDE looks up `start-here-kde` and `distributor-logo` in the icon
    # theme path. Putting our SVG in hicolor/scalable wins for themes
    # that fall back to hicolor.
    local places_dir="/usr/share/icons/hicolor/scalable/places"
    local apps_dir="/usr/share/icons/hicolor/scalable/apps"
    mkdir -p "$places_dir" "$apps_dir"
    install -m 0644 "$src" "$places_dir/start-here-kde.svg"
    install -m 0644 "$src" "$places_dir/start-here.svg"
    install -m 0644 "$src" "$apps_dir/distributor-logo.svg"
    install -m 0644 "$src" "$apps_dir/distributor-logo-symbolic.svg"

    # Symbolic variant for monochrome contexts (e.g. status-bar uses).
    if [ -f "$pack_dir/icons/start-here-symbolic.svg" ]; then
        install -m 0644 "$pack_dir/icons/start-here-symbolic.svg" "$places_dir/start-here-symbolic.svg"
    else
        install -m 0644 "$src" "$places_dir/start-here-symbolic.svg"
    fi

    # Step 2 — overwrite upstream-vendor branding files in place. KDE
    # themes (Breeze, Plasma look-and-feel packages) sometimes hardcode
    # paths to specific upstream files like `distributor-logo.svg` or
    # `auroralogo-*.svg`. Layering alongside doesn't beat those —
    # we have to replace the bytes Aurora ships. Find by filename so
    # we don't depend on knowing the exact paths upstream uses; works
    # across upstream re-organisations.
    local replaced=0
    while IFS= read -r -d '' file; do
        cp -f "$src" "$file"
        replaced=$((replaced + 1))
    done < <(find /usr/share -type f \( \
        -name 'distributor-logo*.svg' \
        -o -name 'auroralogo-*.svg' \
        -o -name 'aurora-banner.svg' \
        -o -name 'aurora-logo*.svg' \
    \) -print0 2>/dev/null)

    if command -v gtk-update-icon-cache >/dev/null 2>&1; then
        gtk-update-icon-cache -q -t /usr/share/icons/hicolor/ 2>/dev/null || true
        # Also rebuild Breeze's cache if it's installed, since we now
        # have a chance our icons get hit there too.
        for theme_dir in /usr/share/icons/breeze /usr/share/icons/breeze-dark; do
            [ -d "$theme_dir" ] && \
                gtk-update-icon-cache -q -t "$theme_dir" 2>/dev/null || true
        done
    fi
    info "  kickoff icon -> hicolor + ${replaced} upstream files overwritten"
}

apply_wallpaper() {
    local pack_dir="$1" component="$2"
    local src="$pack_dir/$component"
    [ -f "$src" ] || { info "  skip wallpaper (not in pack)"; return 0; }

    local wp_dir="/usr/share/wallpapers/Macrosofty/contents/images"
    mkdir -p "$wp_dir"
    install -m 0644 "$src" "$wp_dir/1920x1080.png"

    # KDE6 metadata.json
    cat > /usr/share/wallpapers/Macrosofty/metadata.json <<'EOF'
{
  "KPlugin": {
    "Authors": [{"Name": "Macrosofty"}],
    "Description": "Default Macrosofty wallpaper.",
    "Id": "Macrosofty",
    "License": "Apache-2.0",
    "Name": "Macrosofty"
  },
  "X-KDE-PluginInfo-Name": "Macrosofty"
}
EOF
    info "  wallpaper -> /usr/share/wallpapers/Macrosofty/"
}

apply_motd() {
    local pack_dir="$1" component="$2"
    local src="$pack_dir/$component"
    [ -f "$src" ] || { info "  skip motd (not in pack)"; return 0; }
    install -m 0644 "$src" /etc/motd
    info "  motd -> /etc/motd"
}

apply_grub_distributor() {
    local distributor="$1"
    [ -n "$distributor" ] || { info "  skip GRUB distributor (not in pack)"; return 0; }
    mkdir -p /etc/default/grub.d
    printf 'GRUB_DISTRIBUTOR="%s"\n' "$distributor" > /etc/default/grub.d/99-macrosofty.cfg
    info "  GRUB distributor -> $distributor"
    # Note: actual /boot/grub2/grub.cfg regenerates at install time. We just
    # set the source-of-truth here.
}

apply_grub_background() {
    local pack_dir="$1" component="$2"
    local src="$pack_dir/$component"
    [ -f "$src" ] || { info "  skip GRUB background (not in pack)"; return 0; }

    # GRUB renders a background when in graphics mode (gfxterm -- Fedora's
    # default). Install a PNG into the immutable tree and point GRUB_BACKGROUND
    # at it via a grub.d fragment. We ship a .png (GRUB's png module is
    # near-universal; jpeg is not), and a dark wallpaper rather than a photo so
    # the menu text stays readable on top.
    #
    # ATOMIC CAVEAT: on Fedora Atomic / bootc, /boot/grub2/grub.cfg is managed
    # by bootupd + BLS and regenerates at deploy time, not here. This only sets
    # the source-of-truth; whether it reaches the deployed grub.cfg MUST be
    # boot-verified. Separate fragment (98-) from the GRUB_DISTRIBUTOR one
    # (99-) so the two grub steps never clobber each other.
    local dest_dir=/usr/share/grub/themes/macrosofty
    mkdir -p "$dest_dir"
    install -m 0644 "$src" "$dest_dir/background.png"

    mkdir -p /etc/default/grub.d
    cat > /etc/default/grub.d/98-macrosofty-background.cfg <<EOF
GRUB_BACKGROUND="$dest_dir/background.png"
GRUB_GFXMODE=auto
EOF
    info "  GRUB background -> $dest_dir/background.png (grub.cfg regenerates at deploy)"
}

apply_sddm_background() {
    local pack_dir="$1" component="$2"
    local src="$pack_dir/$component"
    [ -f "$src" ] || { info "  skip SDDM background (not in pack)"; return 0; }

    # Breeze SDDM theme reads its background from /usr/share/sddm/themes/breeze/
    # and the filename is configured in theme.conf. We overlay the most common
    # default filenames; one will be the live one.
    local dest_dir="/usr/share/sddm/themes/breeze"
    if [ -d "$dest_dir" ]; then
        install -m 0644 "$src" "$dest_dir/Background.png"
        info "  SDDM background -> $dest_dir/Background.png"
    else
        info "  skip SDDM background (no breeze theme dir; SDDM not installed?)"
    fi

    # Tell SDDM to use breeze (in case Aurora set a different theme).
    mkdir -p /etc/sddm.conf.d
    cat > /etc/sddm.conf.d/00-macrosofty.conf <<'EOF'
[Theme]
Current=breeze
EOF
}

apply_default_wallpaper() {
    local pack_dir="$1" component="$2"
    [ -n "$component" ] || { info "  skip default wallpaper (not in pack)"; return 0; }

    # The first-run setup wizard + any fresh Plasma session render the SYSTEM
    # DEFAULT wallpaper, wired upstream as /usr/share/backgrounds/default.jxl
    # (+ default-dark.jxl, symlinked to an upstream image). Our other wallpaper
    # steps only touch /usr/share/wallpapers/Macrosofty + the per-user slideshow
    # (applied at first login, AFTER the wizard) -- so the wizard kept upstream
    # art. Overwrite the default so login -> setup -> desktop is one image.
    # Source is our slideshow image; the overlay installs it to
    # /usr/share/backgrounds/macrosofty/ BEFORE this runs (fall back to pack dir).
    local src=""
    if [ -f "/usr/share/backgrounds/macrosofty/$component" ]; then
        src="/usr/share/backgrounds/macrosofty/$component"
    elif [ -f "$pack_dir/$component" ]; then
        src="$pack_dir/$component"
    else
        info "  skip default wallpaper (source '$component' not found)"; return 0
    fi

    local bg_dir=/usr/share/backgrounds
    [ -d "$bg_dir" ] || { info "  skip default wallpaper (no $bg_dir)"; return 0; }

    # Upstream ships these as symlinks; replace with a real file. Aurora's
    # folder.js writes Image=.../default.jxl into the desktop config, so the
    # .jxl path is the one that matters. Qt sniffs image content (not the
    # extension) so a JPEG at a .jxl path decodes; prefer a real JXL via cjxl
    # when present. MUST be boot-verified.
    local wrote=0
    for name in default.jxl default-dark.jxl; do
        local dest="$bg_dir/$name"
        [ -e "$dest" ] || [ -L "$dest" ] || continue
        rm -f "$dest"
        if command -v cjxl >/dev/null 2>&1; then
            cjxl "$src" "$dest" >/dev/null 2>&1 || cp -f "$src" "$dest"
        else
            cp -f "$src" "$dest"
        fi
        wrote=$((wrote + 1))
    done
    info "  default wallpaper -> $bg_dir/default.jxl (+dark): ${wrote} file(s) from $(basename "$src")"
}

apply_plymouth_theme() {
    local pack_dir="$1" component="$2"
    local theme_dir="$pack_dir/$component"
    [ -d "$theme_dir" ] || { info "  skip Plymouth theme (not in pack)"; return 0; }
    [ -f "$theme_dir/macrosofty.plymouth" ] || { info "  skip Plymouth (no macrosofty.plymouth)"; return 0; }

    local dest="/usr/share/plymouth/themes/macrosofty"
    mkdir -p "$dest"
    cp -a "$theme_dir/." "$dest/"

    # Plymouth default-theme selection has multiple layers, any of which
    # can be the one Plymouth actually consults at boot:
    #   1. alternatives system pointing default.plymouth at our theme
    #   2. /usr/share/plymouth/themes/default.plymouth symlink
    #   3. Theme= line in /etc/plymouth/plymouthd.conf
    # In OCI build containers `plymouth-set-default-theme --rebuild-initrd`
    # often fails silently (no kernel installed for dracut), leaving
    # nothing applied. We set ALL three layers explicitly so the active
    # theme is unambiguous regardless of what plymouth-set-default-theme
    # does or doesn't do.

    # Layer 1: alternatives. Tries first because it's what Fedora's
    # tooling expects to manage the symlink chain. Failure is ignored —
    # layer 2 will set the symlink directly.
    if command -v alternatives >/dev/null 2>&1; then
        alternatives --install /usr/share/plymouth/themes/default.plymouth \
            default.plymouth \
            /usr/share/plymouth/themes/macrosofty/macrosofty.plymouth 100 \
            2>/dev/null || true
        alternatives --set default.plymouth \
            /usr/share/plymouth/themes/macrosofty/macrosofty.plymouth \
            2>/dev/null || true
    fi

    # Layer 2: explicit symlink. Plymouth reads
    # /usr/share/plymouth/themes/default.plymouth to find the active
    # theme's .plymouth file. If alternatives didn't take, write the
    # symlink directly. Relative target so it survives bind-mount /
    # ostree-overlay shenanigans.
    ln -sf macrosofty/macrosofty.plymouth \
        /usr/share/plymouth/themes/default.plymouth

    # Layer 3: Theme= line in plymouthd.conf. plymouthd reads this at
    # boot. When set, it overrides the default-theme alternatives.
    mkdir -p /etc/plymouth
    cat > /etc/plymouth/plymouthd.conf <<'PLYMOUTH_CONF'
# Macrosofty Plymouth configuration. Theme set explicitly so Plymouth
# does not fall back to bgrt + spinner watermark (which would surface
# whatever upstream put in /usr/share/plymouth/themes/spinner/).
[Daemon]
Theme=macrosofty
ShowDelay=0
PLYMOUTH_CONF

    # Layer 4: scrub the spinner watermark. The bgrt theme renders the
    # firmware logo (BGRT) plus a watermark overlay sourced from
    # /usr/share/plymouth/themes/spinner/watermark.png. Aurora ships
    # their wordmark at that path, so even if Plymouth falls back to
    # bgrt for any reason (early boot, broken theme load), the user
    # never sees Aurora branding on our distro. Replace with our logo
    # if we have one in the pack; otherwise blank it out.
    local spinner_watermark=/usr/share/plymouth/themes/spinner/watermark.png
    if [ -f /usr/share/plymouth/themes/spinner/spinner.plymouth ]; then
        if [ -f "$theme_dir/logo.png" ]; then
            cp -f "$theme_dir/logo.png" "$spinner_watermark"
        else
            # Truncate to a 1x1 transparent PNG header — invisible
            # rather than wrong-brand. Cheaper than crafting a real
            # PNG; Plymouth tolerates a missing/zero watermark.
            : > "$spinner_watermark"
        fi
    fi

    # Layer 5: scrub the BGRT system-logo watermark. The bgrt theme also
    # renders /usr/share/pixmaps/system-logo-white.png as a centred
    # wordmark when no theme-specific watermark resolves. Upstream
    # (fedora-logos / aurora-logos RPM) ships the Aurora wordmark there.
    # Without this scrub, the first-boot splash showed Aurora because
    # the pre-baked initramfs (built from the kernel RPM before our
    # theme applied) had no theme dir and fell back to bgrt + this
    # logo. Replace with our logo so any fallback can't leak Aurora.
    local system_logo=/usr/share/pixmaps/system-logo-white.png
    if [ -f "$system_logo" ] && [ -f "$theme_dir/logo.png" ]; then
        cp -f "$theme_dir/logo.png" "$system_logo"
    fi

    # Layer 6: rebuild the initramfs. The image ships a kernel-RPM-built
    # initramfs.img that pre-dates this theme apply; it has no theme
    # files baked in and falls back to bgrt + system-logo-white.png at
    # first boot. Regenerate it now, in the OCI build container, so our
    # theme + plymouthd.conf land inside the initrd that ships in the
    # image. dracut --kver picks the kernel actually installed.
    if command -v dracut >/dev/null 2>&1; then
        local kver
        kver=$(ls /usr/lib/modules 2>/dev/null | head -1)
        if [ -n "$kver" ] && [ -d "/usr/lib/modules/$kver" ]; then
            dracut --force --no-hostonly --kver "$kver" \
                "/usr/lib/modules/$kver/initramfs.img" 2>&1 \
                | sed 's/^/    dracut: /' || \
                info "  dracut rebuild failed (continuing — bootc deploy will retry)"
        fi
    fi

    info "  Plymouth theme -> macrosofty (alternatives + symlink + plymouthd.conf; spinner + system-logo watermarks scrubbed; initramfs rebuilt)"
}

apply_lookandfeel() {
    local pack_dir="$1" component="$2"
    local src_dir="$pack_dir/$component"
    [ -d "$src_dir" ] || { info "  skip Look-and-Feel (not in pack)"; return 0; }

    local dest="/usr/share/plasma/look-and-feel/com.macrosofty.desktop"
    mkdir -p "$dest"
    cp -a "$src_dir/." "$dest/"
    info "  Look-and-Feel -> $dest"
}

cmd_apply() {
    local pack_name="${1:-}"
    [ -n "$pack_name" ] || die "usage: macrosofty-theme apply <pack-name>"
    need_root

    local pack_dir="$THEMES_ROOT/$pack_name"
    [ -d "$pack_dir" ] || die "no such pack: $pack_name (looked in $pack_dir)"

    local meta="$pack_dir/pack.json"
    [ -f "$meta" ] || die "pack has no pack.json: $meta"

    info "applying pack: $pack_name ($(jq -r '.displayName // .name' "$meta"))"

    local kickoff wallpaper login motd grubdistro plymouth sddm laf defaultwp grubbg
    kickoff=$(jq -r '.components.kickoffIcon // empty' "$meta")
    wallpaper=$(jq -r '.components.wallpaper // empty' "$meta")
    login=$(jq -r '.components.loginBackground // empty' "$meta")
    motd=$(jq -r '.components.motd // empty' "$meta")
    grubdistro=$(jq -r '.components.grubDistributor // empty' "$meta")
    plymouth=$(jq -r '.components.plymouthTheme // empty' "$meta")
    sddm=$(jq -r '.components.sddmBackground // empty' "$meta")
    laf=$(jq -r '.components.lookAndFeel // empty' "$meta")
    defaultwp=$(jq -r '.components.defaultWallpaper // empty' "$meta")
    grubbg=$(jq -r '.components.grubBackground // empty' "$meta")

    [ -n "$kickoff" ]    && apply_kickoff_icon       "$pack_dir" "$kickoff"
    [ -n "$wallpaper" ]  && apply_wallpaper          "$pack_dir" "$wallpaper"
    [ -n "$motd" ]       && apply_motd               "$pack_dir" "$motd"
    [ -n "$grubdistro" ] && apply_grub_distributor   "$grubdistro"
    [ -n "$grubbg" ]     && apply_grub_background     "$pack_dir" "$grubbg"
    [ -n "$sddm" ]       && apply_sddm_background    "$pack_dir" "$sddm"
    [ -n "$defaultwp" ]  && apply_default_wallpaper  "$pack_dir" "$defaultwp"
    [ -n "$plymouth" ]   && apply_plymouth_theme     "$pack_dir" "$plymouth"
    [ -n "$laf" ]        && apply_lookandfeel        "$pack_dir" "$laf"

    mkdir -p "$(dirname "$STATE_FILE")"
    echo "$pack_name" > "$STATE_FILE"
    info "applied pack: $pack_name"
}

case "${1:-}" in
    apply)    shift; cmd_apply   "$@" ;;
    list)     cmd_list ;;
    current)  cmd_current ;;
    -h|--help|"")
        sed -n '3,/^$/p' "$0" | sed 's/^# \?//'
        ;;
    *) die "unknown command: $1 (try --help)" ;;
esac
