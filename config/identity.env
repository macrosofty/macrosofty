# Macrosofty brand identity — single source of truth.
#
# Sourced by every script that needs to know "what is the brand?". Edit
# this file to rebrand wholesale — every downstream artefact (os-release,
# motd, .desktop strings, hostname, the scrub passes) picks up the new
# values from the next image build.
#
# All values are shell-sourceable (POSIX env vars). Don't put complex
# logic here — it's data, not code.

# --- Brand strings ---------------------------------------------------------
BRAND_NAME="Macrosofty"
BRAND_NAME_LOWER="macrosofty"
BRAND_TAGLINE="A Linux that doesn't suck."
BRAND_PROMISE="We open the door — not just a window to peek through."
BRAND_FOOTER="Free for everyone. Forever."

# --- Brand URLs ------------------------------------------------------------
# Homepage, docs, repo, issue tracker, support. Used in os-release and as
# the targets when the scrub script rewrites upstream URLs.
BRAND_HOMEPAGE_URL="https://macrosofty.org"
BRAND_DOCS_URL="https://macrosofty.org"
BRAND_REPO_URL="https://github.com/macrosofty/macrosofty"
BRAND_ISSUES_URL="https://github.com/macrosofty/macrosofty/issues"
BRAND_DISCUSSIONS_URL="https://github.com/macrosofty/macrosofty/discussions"
BRAND_SUPPORT_URL="https://github.com/macrosofty/macrosofty/discussions"

# --- System defaults -------------------------------------------------------
# Default /etc/hostname value. User can override during install or in
# System Settings. Setting here ensures we don't inherit "aurora".
BRAND_DEFAULT_HOSTNAME="macrosofty"

# --- OCI image registry ----------------------------------------------------
# Where our images live. Used by the scrub script to rewrite upstream
# OCI refs (e.g. "ghcr.io/ublue-os/aurora:stable") to ours
# (e.g. "ghcr.io/macrosofty/padkos:stable") in places like the
# ublue-os motd that show the source image to the user.
BRAND_OCI_PREFIX="ghcr.io/macrosofty"

# --- Per-edition upstream OCI refs -----------------------------------------
# Edition → upstream OCI ref. Format: "<edition>:<upstream_ref>" per line.
# When the scrub script runs with a specific edition (via the EDITION env
# var or first positional arg), it looks up the upstream ref here and
# adds a per-edition substitution to UPSTREAM_URL_SUBS — so the motd
# shows our edition's image path instead of the upstream's.
#
# Adding a new edition: add one row here. Adding a new edition that
# uses an existing upstream: still add a row.
EDITION_UPSTREAM_OCI="\
hearty:ghcr.io/ublue-os/aurora
chunky:ghcr.io/ublue-os/aurora-dx
chunky-lj:ghcr.io/ublue-os/aurora
padkos:ghcr.io/ublue-os/aurora
braai:ghcr.io/ublue-os/bazzite"

# --- Upstream brands to scrub from inherited image assets ------------------
# Whitespace-separated list. Used by scripts/scrub-upstream-branding.sh
# to rewrite Name/Comment/etc. fields in inherited .desktop files,
# /etc/profile.d shell greetings, and so on. Add an entry when a new
# upstream gets pulled in (e.g. if Bokkie pulls in a Kinoite-derived
# brand we need to scrub).
UPSTREAM_BRANDS="Aurora Bazzite"
UPSTREAM_BRANDS_LOWER="aurora bazzite"

# --- Upstream URL substitutions --------------------------------------------
# Pipe-separated FROM|TO pairs, one per line. Used by the scrub script
# to rewrite upstream URLs (in shell greetings, .desktop comments, etc.)
# to point at our channels instead. Order matters: longest-prefix first
# so e.g. "docs.getaurora.dev" matches before bare "getaurora.dev".
UPSTREAM_URL_SUBS="\
docs.getaurora.dev|${BRAND_HOMEPAGE_URL#https://}
getaurora.dev|${BRAND_HOMEPAGE_URL#https://}
docs.bazzite.gg|${BRAND_HOMEPAGE_URL#https://}
bazzite.gg|${BRAND_HOMEPAGE_URL#https://}
github.com/ublue-os/aurora|${BRAND_REPO_URL#https://}
github.com/ublue-os/bazzite|${BRAND_REPO_URL#https://}"
